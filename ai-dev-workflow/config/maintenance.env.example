# Maintenance profile: post-delivery feature changes / bug fixes
# Goal: allow smaller batches and graceful fallback while keeping
# execution tasks file-writing first.

LLM_MODE=hybrid
EXECUTION_CLI_ONLY=1
EXECUTION_API_FALLBACK=1
EXECUTION_REVIEW_INTERVAL=2
MAX_DAILY_COST_USD=8.0
MAX_TOKENS_PER_TASK=35000
VALIDATION_TIMEOUT_SECONDS=900
REVIEW_CLI_FALLBACK=1
REVIEW_CLI_TIMEOUT_SECONDS=600

# CLI routing
MODEL_BACKEND=gpt-5.2-codex
MODEL_FRONTEND=gemini-3-flash-preview
MODEL_REVIEW=claude-opus-4-6
MODEL_PLANNING=gpt-5.2-codex
