# ===== Mode =====
# cli | api | hybrid
LLM_MODE=hybrid
EXECUTION_CLI_ONLY=1
EXECUTION_API_FALLBACK=0
EXECUTION_REVIEW_INTERVAL=0

# ===== OpenAI-compatible relay =====
OPENAI_API_BASE=https://your-openai-relay.example.com/v1
OPENAI_API_KEY=<OPENAI_API_KEY>

# ===== Anthropic-compatible relay =====
ANTHROPIC_API_BASE=https://your-anthropic-relay.example.com/v1
ANTHROPIC_API_KEY=<ANTHROPIC_API_KEY>

# ===== Gemini-compatible relay =====
GEMINI_API_BASE=https://your-gemini-relay.example.com/v1
GEMINI_API_KEY=<GEMINI_API_KEY>

# ===== Model mapping =====
MODEL_BACKEND=gpt-5.2-codex
MODEL_FRONTEND=gemini-3-flash-preview
MODEL_FRONTEND_LITE=gemini-3.1-flash-lite-preview
MODEL_ARCHITECT=gpt-5.2-codex
MODEL_REVIEW=claude-opus-4-6
MODEL_PLANNING=gpt-5.2-codex

# ===== CrewAI runtime routing =====
# openai | anthropic | gemini
CREWAI_PROVIDER=openai
CREWAI_MODEL_NAME=gpt-5.2-codex
CREWAI_MODEL_ORCHESTRATOR=gpt-5.2-codex
CREWAI_MODEL_BACKEND=gpt-5.2-codex
CREWAI_MODEL_FRONTEND=gemini-3-flash-preview
CREWAI_MODEL_AUDIT=claude-opus-4-6
CREWAI_BACKEND_API_BASE=https://your-openai-relay.example.com/v1
CREWAI_FRONTEND_API_BASE=https://your-gemini-relay.example.com/v1
CREWAI_AUDIT_API_BASE=https://your-anthropic-relay.example.com/v1
# CREWAI_BACKEND_API_KEY=<OPENAI_API_KEY>
# CREWAI_FRONTEND_API_KEY=<GEMINI_API_KEY>
# CREWAI_AUDIT_API_KEY=<ANTHROPIC_API_KEY>
# CREWAI_API_BASE=https://your-openai-relay.example.com/v1
# CREWAI_API_KEY=<OPENAI_API_KEY>

# ===== CrewAI/OpenAI compatibility =====
OPENAI_BASE_URL=https://your-openai-relay.example.com/v1
OPENAI_MODEL_NAME=gpt-5.2-codex

# ===== Cost / runtime control =====
MAX_DAILY_COST_USD=10.0
MAX_TOKENS_PER_TASK=50000
VALIDATION_TIMEOUT_SECONDS=900
REVIEW_CLI_FALLBACK=1
REVIEW_CLI_TIMEOUT_SECONDS=600
# 开发期请参考: ai-dev-workflow/config/development.env.example
# 迭代期请参考: ai-dev-workflow/config/maintenance.env.example
